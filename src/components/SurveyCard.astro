---
const { survey } = Astro.props;

const surveyMetrics = [
  survey.num_hosts && { label: 'Hosts', value: survey.num_hosts },
  survey.num_confirmed_satellites && {
    label: 'Satellites',
    value: survey.num_confirmed_satellites
  },
  survey.num_dwarfs && { label: 'Field dwarfs', value: survey.num_dwarfs }
].filter(Boolean);
---

<article class:list={['survey-card', `survey-card--${survey.slug}`]}>
  <div class="survey-card__body">
    <p class="eyebrow">{survey.kicker}</p>
    <h3>{survey.name}</h3>
    <p>{survey.tagline}</p>
  </div>
  {
    surveyMetrics.length > 0 && (
      <div class="survey-card__stats" aria-label={`${survey.name} sample counts`}>
        {surveyMetrics.map((metric) => (
          <div class="stat-chip">
            <strong data-countup data-countup-target={metric.value}>{metric.value}</strong>
            <span>{metric.label}</span>
          </div>
        ))}
      </div>
    )
  }
  <div class="survey-card__actions">
    <a class="text-link" href={survey.route}>Open survey page</a>
    <a class="text-link" href={`${survey.route}#data`}>View data products</a>
  </div>
</article>
