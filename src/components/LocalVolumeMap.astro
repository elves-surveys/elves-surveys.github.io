const backgroundPoints = [
  [94, 250, 1.7], [152, 112, 1.5], [282, 196, 1.4], [354, 112, 1.6],
  [516, 170, 1.4], [546, 376, 1.7], [432, 454, 1.4], [188, 522, 1.6],
  [72, 388, 1.4], [312, 558, 1.5], [214, 118, 1.3], [548, 270, 1.5],
