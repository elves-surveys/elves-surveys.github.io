---

<figure class="local-volume-map" aria-labelledby="local-volume-map-title">
  <svg
    class="local-volume-map__svg"
    viewBox="0 0 600 600"
    role="img"
    aria-labelledby="local-volume-map-title local-volume-map-desc"
  >
    <title id="local-volume-map-title">Stylized Local Volume map of the ELVES survey family</title>
    <desc id="local-volume-map-desc">
      A schematic circular Local Volume containing dense Milky Way-mass host environments for ELVES,
      lower-mass dwarf-host environments for ELVES-Dwarf, and isolated field dwarfs for ELVES-Field.
    </desc>
    <defs>
      <radialGradient id="local-volume-glow" cx="50%" cy="45%" r="56%">
        <stop offset="0%" stop-color="#eef5ff" stop-opacity="0.72" />
        <stop offset="72%" stop-color="#ffffff" stop-opacity="0.12" />
        <stop offset="100%" stop-color="#ffffff" stop-opacity="0" />
      </radialGradient>
    </defs>

    <circle class="map-volume-fill" cx="300" cy="300" r="260" aria-hidden="true" />
    <circle class="map-volume-boundary" cx="300" cy="300" r="260" aria-hidden="true" />
    <text class="map-volume-label" x="300" y="20" text-anchor="middle" aria-hidden="true">Local Volume</text>

    <g class="map-context" aria-hidden="true">
      {backgroundPoints.map(([cx, cy, r]) => <circle class="map-background-point" cx={cx} cy={cy} r={r} />)}
    </g>

    <g class="map-layer map-layer-elves" aria-hidden="true">
      {elvesGroups.map((group) => (
        <g class="map-group map-node-elves">
          <circle class="map-halo" cx={group.cx} cy={group.cy} r={group.halo} />
          <circle class="map-host map-host-elves" cx={group.cx} cy={group.cy} r={group.core} />
          {group.satellites.map(([cx, cy, r]) => (
            <circle class="map-satellite map-satellite-elves" cx={cx} cy={cy} r={r} />
          ))}
        </g>
      ))}
    </g>

    <g class="map-layer map-layer-dwarf" aria-hidden="true">
      {dwarfGroups.map((group) => (
        <g class="map-group map-node-dwarf">
          <circle class="map-halo" cx={group.cx} cy={group.cy} r={group.halo} />
          <circle class="map-host map-host-dwarf" cx={group.cx} cy={group.cy} r={group.core} />
          {group.satellites.map(([cx, cy, r]) => (
            <circle class="map-satellite map-satellite-dwarf" cx={cx} cy={cy} r={r} />
          ))}
        </g>
      ))}
    </g>

    <g class="map-layer map-layer-field" aria-hidden="true">
      {fieldDwarfs.map(([cx, cy, r]) => (
        <circle class="map-node-field" cx={cx} cy={cy} r={r} />
      ))}
    </g>
  </svg>

  <figcaption class="local-volume-map__legend">
    <span><i class="legend-dot legend-dot--elves"></i><em>MW-mass hosts</em></span>
    <span><i class="legend-dot legend-dot--dwarf"></i><em>Dwarf hosts</em></span>
    <span><i class="legend-dot legend-dot--field"></i><em>Field dwarfs</em></span>
  </figcaption>
</figure>
