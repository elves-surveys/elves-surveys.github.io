---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TeamMemberCard from '../../components/TeamMemberCard.astro';
import team from '../../content/team.json';

const coreMembers = team.filter((member) => member.memberType !== 'collaborator');
const collaborators = team.filter((member) => member.memberType === 'collaborator');
const hasCollaborators = collaborators.length > 0;
---

<BaseLayout
  title="Team | ELVES Surveys"
  description="Core members of the ELVES survey family."
>

  <section class="page-section page-section--after-compact-hero" aria-labelledby="core-team-heading">
    <div class="section-heading">
    <p class="eyebrow">Survey team</p>
      <h2 id="core-team-heading">Core Members</h2>
    </div>
    <div class="team-grid">
      {coreMembers.map((member) => <TeamMemberCard member={member} />)}
    </div>
  </section>

  {
    hasCollaborators && (
      <section class="page-section page-section--compact page-section--band" aria-labelledby="collaborators-heading">
        <div class="collaborator-panel">
          <div class="section-heading">
            <p class="eyebrow">Collaborators</p>
            <h2 id="collaborators-heading">Collaborators also include</h2>
          </div>
          <div class="collaborator-list">
            {
              collaborators.map((person) => (
                <article class="collaborator-item">
                  <h3>
                    {
                      person.url ? (
                        <a href={person.url} target="_blank" rel="noopener noreferrer">{person.name}</a>
                      ) : (
                        person.name
                      )
                    }
                  </h3>
                  {person.institution && <p>{person.institution}</p>}
                  {
                    person.email && (
                      <a class="collaborator-item__email" href={`mailto:${person.email}`}>{person.email}</a>
                    )
                  }
                </article>
              ))
            }
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
