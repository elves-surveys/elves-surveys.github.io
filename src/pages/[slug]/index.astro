---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DataProducts from '../../components/DataProducts.astro';
import PaperList from '../../components/PaperList.astro';
import surveys from '../../content/surveys.json';
import papers from '../../content/papers.json';
import dataProducts from '../../content/data-products.json';

export function getStaticPaths() {
  return surveys.map((survey) => ({
    params: { slug: survey.slug },
    props: { survey }
  }));
}

const { survey } = Astro.props;
const surveyPapers = papers.filter((paper) => paper.surveys?.includes(survey.slug));
const surveyProducts = dataProducts.filter((product) => product.survey === survey.slug);
const surveyMetrics = [
  survey.num_hosts && { label: 'Hosts', value: survey.num_hosts },
  survey.num_confirmed_satellites && {
    label: 'Satellites',
    value: survey.num_confirmed_satellites
  },
  survey.num_dwarfs && { label: 'Field dwarfs', value: survey.num_dwarfs }
].filter(Boolean);
---

<BaseLayout title={`${survey.name} | ELVES Surveys`} description={survey.description}>
  <section class="hero hero--survey">
    <div class="survey-hero__copy">
      <p class="eyebrow">{survey.kicker}</p>
      <h1>{survey.name}</h1>
      <p class="hero__lede">{survey.tagline}</p>
    </div>
    <dl class="hero-meta hero-meta--survey">
      <div>
        <dt>Host type</dt>
        <dd>{survey.hostGalaxyType}</dd>
      </div>
      {
        surveyMetrics.length > 0 && (
          <div>
            <dt>Sample size</dt>
            <dd>
              <span class="inline-stat-list">
                {surveyMetrics.map((metric) => (
                  <span>
                    <strong>{metric.value}</strong>
                    {metric.label}
                  </span>
                ))}
              </span>
            </dd>
          </div>
        )
      }
    </dl>
  </section>

  <section class="page-section page-section--survey-brief" aria-labelledby="survey-brief-heading">
    <div class="section-heading section-heading--compact">
      <p class="eyebrow">Survey snapshot</p>
      <h2 id="survey-brief-heading">Overview</h2>
    </div>
    <div class="survey-brief">
      <div class="prose prose--compact">
        {survey.overview.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>

  <section class="page-section" aria-labelledby="papers-heading">
    <div class="section-heading">
      <p class="eyebrow">Papers</p>
      <h2 id="papers-heading">Papers</h2>
    </div>
    <PaperList papers={surveyPapers} />
  </section>

  <DataProducts products={surveyProducts} />

</BaseLayout>
