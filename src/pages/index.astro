---
import BaseLayout from '../layouts/BaseLayout.astro';
import PaperList from '../components/PaperList.astro';
import SurveyCard from '../components/SurveyCard.astro';
import AcronymReveal from '../components/AcronymReveal.astro';
import LocalVolumeMap from '../components/LocalVolumeMap.astro';
import surveys from '../content/surveys.json';
import papers from '../content/papers.json';

const featuredPapers = papers.filter((paper) => paper.featured);

const dataAccessCards = [
  {
    name: 'ELVES',
    description: 'Data products for Milky Way-mass host satellite systems.',
    href: '/elves/#data',
    buttonLabel: 'Open ELVES data'
  },
  {
    name: 'ELVES-Dwarf',
    description: 'Data products for dwarf-host satellite systems.',
    href: '/elves-dwarf/#data',
    buttonLabel: 'Open ELVES-Dwarf data'
  },
  {
    name: 'ELVES-Field',
    description: 'Data products for isolated field dwarfs.',
    href: '/elves-field/#data',
    buttonLabel: 'Open ELVES-Field data'
  }
];
---

<BaseLayout
  title="ELVES Surveys"
  description="Public portal for ELVES, ELVES-Dwarf, and ELVES-Field survey papers and data products."
>
  <section class="hero hero--home">
    <div class="hero__content hero__content--compact">
      <h1 style="font-size: 3em; max-width: 20ch;">The <span style="font-family: sans-serif;">ELVES</span> Surveys</h1>
      <AcronymReveal />
      <p class="hero__lede" style="font-size: 0.95rem;">
        A coordinated family of surveys characterizing the dwarf-galaxy populations around
        Milky Way analogs (<em>ELVES</em>), around dwarf hosts (<em>ELVES-Dwarf</em>), and in the field (<em>ELVES-Field</em>). 
      </p>
      <div class="hero__actions">
        <a class="button" href="#surveys">Browse surveys</a>
        <a class="button button--secondary" href="#data-access">View data products</a>
      </div>
    </div>
    <LocalVolumeMap />
  </section>

  <section class="page-section" id="surveys" aria-labelledby="surveys-heading">
    <div class="section-heading">
      <p class="eyebrow">ELVES Surveys Family</p>
      <h2 id="surveys-heading" style="font-size: 1.75rem;">Three Local Volume Samples of Dwarf Galaxies</h2>
    </div>
    <div class="survey-grid">
      {surveys.map((survey) => <SurveyCard survey={survey} />)}
    </div>
  </section>

  <section class="page-section" aria-labelledby="featured-papers-heading">
    <div class="section-heading section-heading--split">
      <div>
        <p class="eyebrow">Papers</p>
        <h2 id="featured-papers-heading">Featured papers</h2>
      </div>
      <a class="button button--secondary" href="/papers/">View all papers</a>
    </div>
    <PaperList papers={featuredPapers} />
  </section>

  <section class="page-section page-section--compact" id="data-access" aria-labelledby="data-access-heading">
    <div class="data-access">
      <div class="section-heading section-heading--compact">
        <p class="eyebrow">Data</p>
        <h2 id="data-access-heading">Data access</h2>
        <p>
          Public catalogs and documentation are organized by survey. Each survey page includes the relevant catalogs,
          distance measurements, imaging products, completeness information, and citation guidance.
        </p>
      </div>
      <div class="data-access-grid">
        {
          dataAccessCards.map((card) => (
            <article class="data-access-card">
              <div>
                <h3>{card.name}</h3>
                <p>{card.description}</p>
              </div>
              <a class="button button--secondary" href={card.href}>{card.buttonLabel}</a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="page-section page-section--compact" aria-labelledby="contact-heading">
    <div class="contact-panel">
      <div class="contact-panel__heading">
        <p class="eyebrow">Citation</p>
        <h2 id="contact-heading">Contact and Citation</h2>
      </div>
      <div class="contact-panel__body">
        <p>
          If you use data products from these surveys, please cite the core survey paper and/or relevant science papers.
          If you have questions about the data, please contact the survey team via email.
        </p>

        {(() => {
          const keyPapers = [
            { label: 'ELVES', paper: papers.find(p => p.id === 'elves-carlsten2022')! },
            { label: 'ELVES-Dwarf', paper: papers.find(p => p.id === 'elves-dwarf-paper1')! },
            { label: 'ELVES-Field', paper: papers.find(p => p.id === 'elves-field-sample-paper')! },
          ];
          return (
            <div class="citation-tabs" id="citation-tabs">
              <div class="citation-tabs__buttons" role="tablist" aria-label="Survey citations">
                {keyPapers.map(({ label }, i) => (
                  <button
                    class="citation-tab-btn"
                    role="tab"
                    aria-selected={i === 0 ? 'true' : 'false'}
                    aria-controls={`bibtex-panel-${i}`}
                    id={`bibtex-tab-${i}`}
                    data-tab-index={i}
                  >{label}</button>
                ))}
              </div>
              {keyPapers.map(({ paper }, i) => (
                <div
                  class="citation-tabs__panel"
                  role="tabpanel"
                  id={`bibtex-panel-${i}`}
                  aria-labelledby={`bibtex-tab-${i}`}
                  hidden={i !== 0}
                >
                  <p class="citation-tabs__note">{paper.citationNote}</p>
                  <div class="bibtex-block">
                    <pre class="bibtex-pre"><code>{paper.bibtex}</code></pre>
                    <button class="bibtex-copy-btn" data-bibtex={paper.bibtex} aria-label="Copy BibTeX">Copy</button>
                  </div>
                </div>
              ))}
            </div>
          );
        })()}

        <a class="text-link" href="/team/">View the survey team</a>
      </div>
    </div>
  </section>

  <script>
    (() => {
      const tabs = document.querySelectorAll<HTMLButtonElement>('.citation-tab-btn');
      const panels = document.querySelectorAll<HTMLElement>('.citation-tabs__panel');

      tabs.forEach((btn) => {
        btn.addEventListener('click', () => {
          const idx = Number(btn.dataset.tabIndex);
          tabs.forEach((t, i) => t.setAttribute('aria-selected', i === idx ? 'true' : 'false'));
          panels.forEach((p, i) => { p.hidden = i !== idx; });
        });
      });

      document.querySelectorAll<HTMLButtonElement>('.bibtex-copy-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const text = btn.dataset.bibtex ?? '';
          try {
            await navigator.clipboard.writeText(text);
            btn.textContent = 'Copied!';
            setTimeout(() => { btn.textContent = 'Copy'; }, 1800);
          } catch {
            btn.textContent = 'Copy failed';
            setTimeout(() => { btn.textContent = 'Copy'; }, 1800);
          }
        });
      });
    })();
  </script>

  <script>
    (() => {
      const counters = Array.from(document.querySelectorAll('[data-countup]'));
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const formatter = new Intl.NumberFormat();

      const setCounterValue = (counter, value) => {
        counter.textContent = formatter.format(value);
      };

      const animateCounter = (counter) => {
        if (counter.dataset.countupDone === 'true') return;

        counter.dataset.countupDone = 'true';
        const target = Number(counter.dataset.countupTarget || counter.textContent?.replace(/,/g, ''));

        if (!Number.isFinite(target)) return;

        if (reducedMotion) {
          setCounterValue(counter, target);
          return;
        }

        const duration = 1150;
        const startTime = performance.now();

        const tick = (now) => {
          const progress = Math.min((now - startTime) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          setCounterValue(counter, Math.round(target * eased));

          if (progress < 1) {
            requestAnimationFrame(tick);
          } else {
            setCounterValue(counter, target);
          }
        };

        setCounterValue(counter, 0);
        requestAnimationFrame(tick);
      };

      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              observer.unobserve(entry.target);
              animateCounter(entry.target);
            });
          },
          { threshold: 0.42 }
        );

        counters.forEach((counter) => observer.observe(counter));
      } else {
        counters.forEach(animateCounter);
      }
    })();
  </script>
</BaseLayout>
