---
import '../styles/global.css';

const {
  title = 'ELVES Surveys',
  description = 'Public portal for the ELVES family of Local Volume dwarf-galaxy surveys.'
} = Astro.props;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/elves/', label: 'ELVES' },
  { href: '/elves-dwarf/', label: 'ELVES-Dwarf' },
  { href: '/elves-field/', label: 'ELVES-Field' },
  { href: '/team/', label: 'Team' }
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-wordmark" href="/" aria-label="ELVES Surveys home">
          <img
            class="site-wordmark__icon"
            src="/logos/elves-icon-light.svg"
            width="80"
            height="80"
            alt=""
            aria-hidden="true"
          />
          <span>ELVES Surveys</span>
        </a>
        <nav class="site-nav" aria-label="Main navigation">
          {
            navItems.map((item) => (
              <a
                class:list={[
                  'site-nav__link',
                  currentPath === item.href && 'site-nav__link--active'
                ]}
                href={item.href}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <p>The ELVES Surveys Team</p>
        <p>Built by Jiaxuan Li, 2026</p>
      </div>
    </footer>
  </body>
</html>
